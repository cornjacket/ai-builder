# Sandbox: ignore everything except README.md
sandbox/*
!sandbox/README.md

# Python bytecode
**/__pycache__/
**/*.pyc

# ai-builder runtime artifacts
ai-builder/logs/
ai-builder/execution.log
ai-builder/TASK-*.md
!ai-builder/TASK-TEMPLATE.md

# Scratch/experimental copies
ai-builder/orchestrator/*.py.gemini
